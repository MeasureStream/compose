{
  "name": "ttn-mqtt-sink",
  "config": {
    "connector.class": "io.lenses.streamreactor.connect.mqtt.sink.MqttSinkConnector",
    "tasks.max": "1",
    "topics": "ttn-downlink",
    "connect.mqtt.hosts": "${MQTT_BROKER}",
    "connect.mqtt.username": "${MQTT_USERNAME}",
    "connect.mqtt.password": "${MQTT_PASSWORD}",
    "connect.mqtt.client.id": "kafka-backend-sink",
    "connect.mqtt.clean": "true",
    "connect.mqtt.service.quality": "1",
    "connect.mqtt.kcql": "INSERT INTO v3/stm32wl-end-node-demo-mslab@ttn/devices/lora-e5/down/push SELECT * FROM ttn-downlink IGNORE device_id",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false"
  }
}
